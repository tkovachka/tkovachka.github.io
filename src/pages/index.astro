---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featured = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.startDate.localeCompare(a.data.startDate));

const cleanId = (id: string) => id.replace(/\.mdx?$/, '');
---

<BaseLayout title="Home" description="Software Engineer portfolio of Teodora Kovachka.">
  <Nav slot="nav" />

  <!-- ── Hero ──────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-inner">

      <p class="hero-label">Software Engineer, AI enthusiast, Relentless Experimenter</p>

      <h1 class="hero-name">
        Teodora<br /><em>Kovachka</em>
      </h1>

      <div class="hero-rule"></div>
      <!-- todo personalize -->
      <p class="hero-bio">
        I build software that brings me joy and write about it.
        Currently working on <strong>moving a couple apps to production</strong>.
      </p>

      <div class="hero-actions">
        <a href="/projects" class="btn-primary">View Projects</a>
        <a href="/about" class="btn-ghost">About Me →</a>
      </div>
    </div>
    <div class="hero-photo-wrap" id="photo-wrap">
      <img
          src="/images/profile.jpg"
          alt="Teodora Kovachka"
          class="hero-photo"
          width="420"
          height="560"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          onload="this.closest('.hero-photo-wrap').classList.add('loaded')"
      />
      <script>
        const img = document.querySelector('.hero-photo');
        if (img?.complete) img.closest('.hero-photo-wrap')?.classList.add('loaded');
      </script>
    </div>

  </section>

  <!-- ── Featured Work ─────────────────────────────────── -->
  {featured.length > 0 && (
    <section class="section-featured">
      <div class="max-w-5xl mx-auto px-6">
        <div class="section-header">
          <div>
            <p class="section-label">Selected Work</p>
            <h2 class="section-title">Featured Projects</h2>
          </div>
          <a href="/projects" class="see-all">All projects →</a>
        </div>

        <div class="grid sm:grid-cols-2 gap-4">
          {featured.map((project) => (
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              status={project.data.status}
              stack={project.data.stack}
              slug={cleanId(project.id)}
              featured={project.data.featured}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ── About strip ───────────────────────────────────── -->
  <section class="about-strip">
    <div class="max-w-5xl mx-auto px-6 about-grid">
      <div class="about-left">
        <p class="section-label">About</p>
        <h2 class="section-title">A little<br /><em>about me</em></h2>
      </div>
      <div class="about-right">
        <p class="about-text">
          I believe that everything happens for a reason. And that each of us has a mission
          to complete in our lives. I am still searching for my mission somewhere in between all the
          code, AI, yoga, dance, friends, family... I have no idea what my
          mission is yet - but I sure am having fun finding out.
        </p>
        <a href="/about" class="about-link">Read more →</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* ── Hero ───────────────────────────────── */
  .hero {
    position: relative;
    max-width: 72rem;
    margin: 0 auto;
    padding: 5rem 1.5rem 6rem;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4rem;
    align-items: center;
  }
  @media (max-width: 768px) {
    .hero { grid-template-columns: 1fr; }
    .hero-photo-wrap { display: none; }
  }

  .hero-inner { position: relative; z-index: 2; max-width: 42rem; }

  .hero-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--burgundy);
    margin-bottom: 1.5rem;
  }

  .hero-name {
    font-family: 'Playfair Display', serif;
    font-size: clamp(4rem, 10vw, 7rem);
    font-weight: 700;
    line-height: 0.95;
    color: #0D0D0D;
    margin-bottom: 1.75rem;
    letter-spacing: -0.02em;
  }
  .hero-name em {
    font-style: italic;
    color: var(--burgundy);
  }

  .hero-rule {
    width: 4rem;
    height: 4px;
    background: var(--burgundy);
    margin-bottom: 2rem;
  }

  .hero-bio {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.1rem;
    line-height: 1.7;
    color: #444;
    max-width: 44ch;
    margin-bottom: 2.5rem;
  }
  .hero-bio strong { color: #0D0D0D; font-weight: 600; }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1.75rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: #0D0D0D;
    color: var(--cream);
    padding: 0.85rem 1.75rem;
    text-decoration: none;
    transition: background 0.2s;
  }
  .btn-primary:hover { background: var(--burgundy); }

  .btn-ghost {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #0D0D0D;
    text-decoration: none;
    border-bottom: 2px solid #0D0D0D;
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;
  }
  .btn-ghost:hover { color: var(--burgundy); border-color: var(--burgundy); }

  /* ── Photo frame ─────────────────────── */
  .hero-photo-wrap {
    position: relative;
    flex-shrink: 0;
    width: 300px;
    height: 400px;
  }

  .hero-photo-wrap::before {
    content: '';
    position: absolute;
    inset: 0;
    border: 2px solid var(--burgundy);
    transform: translate(12px, 12px);
    z-index: 0;
  }

  .hero-photo-wrap::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(
        135deg,
        #F0ECEB 0%,
        #FAF8F5 50%,
        #F0ECEB 100%
    );
    background-size: 200% 200%;
    animation: shimmer 1.6s ease-in-out infinite;
    transition: opacity 0.3s ease;
  }

  .hero-photo-wrap.loaded::after {
    opacity: 0;
    pointer-events: none;
  }

  @keyframes shimmer {
    0%   { background-position: 0% 50%; }
    50%  { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .hero-photo {
    display: block;
    position: relative;
    z-index: 1;
    width: 300px;
    height: 400px;
    object-fit: cover;
    object-position: center top;
  }

  /* ── Shared section styles ──────────── */
  .section-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--burgundy);
    margin-bottom: 0.5rem;
  }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 3.5vw, 2.5rem);
    font-weight: 700;
    color: #0D0D0D;
    line-height: 1.15;
  }
  .section-title em {
    font-style: italic;
    color: var(--burgundy);
  }

  /* ── Featured ───────────────────────── */
  .section-featured {
    border-top: 1px solid #E8E8E8;
    padding: 5rem 0;
  }
  .section-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .see-all {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #888;
    text-decoration: none;
    transition: color 0.2s;
  }
  .see-all:hover { color: var(--burgundy); }

  /* ── About strip ────────────────────── */
  .about-strip {
    background: #F5F3F0;
    border-top: 1px solid #E8E8E8;
    padding: 5rem 0;
  }
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  @media (max-width: 640px) {
    .about-grid { grid-template-columns: 1fr; gap: 2rem; }
  }
  .about-text {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    line-height: 1.8;
    color: #333;
    margin-bottom: 1.5rem;
    max-width: 48ch;
  }
  .about-link {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--burgundy);
    text-decoration: none;
    border-bottom: 2px solid var(--burgundy);
    padding-bottom: 2px;
    transition: opacity 0.2s;
  }
  .about-link:hover { opacity: 0.7; }

  /* Page fade-in */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .hero-inner { animation: fadeUp 0.5s ease both; }
</style>
