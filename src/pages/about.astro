---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import {getCollection, render} from 'astro:content';

const rawSections = await getCollection('about');

const sections = rawSections.sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(
    sections.map(async (s) => {
        const {Content} = await render(s);
        return {section: s, Content};
    })
);

const toId = (id: string) => id.replace(/\.mdx?$/, '');

const stack = [
    'React', 'Astro', 'Tailwind CSS', 'Node.js', 'FastAPI', 'Spring Boot', 'ASP.NET', 'Streamlit', 'Flutter', 'Dart',
    'Android Studio', 'JavaScript', 'Java', 'Thymeleaf', 'Python', 'Django'
];
const aiStack = [
    'Prompt Engineering', 'Context Engineering', 'LLM APIs', 'AI Agents', 'RAG',
    'langchain', 'scikit-learn', 'pandas', 'NumPy', 'Jupyter', 'Hugging Face',
];
const cloudStack = [
    'Azure App Service', 'Azure Functions', 'Azure SQL Database', 'Azure Blob Storage', 'Azure Cosmos DB',
    'Azure Key Vault', 'Azure API Management', 'Azure Application Insights',
];
const tooling = [
    'Git', 'GitHub Actions', 'Docker', 'GitHub Pages', 'VS Code', 'WebStorm',
    'Postman', 'Figma', 'REST APIs', 'CI/CD', 'Static Site Generation',
    'Agile', 'Software Architecture', 'Data Modelling', 'Automation'
];
---

<BaseLayout
        title="About"
        description="About me - background and what I'm currently working on.">

    <Nav slot="nav"/>

    <div class="max-w-5xl mx-auto px-6 pt-20 pb-24">

        <header class="page-header">
            <div class="header-grid">
                <div class="header-left">
                    <p class="section-label">About</p>
                    <h1 class="page-title">The longer<br/><em>version.</em></h1>
                </div>

                <nav class="agenda" aria-label="Page sections">
                    {rendered.map(({section}, i) => (
                            <a href={`#${toId(section.id)}`} class="agenda-item">
                                <span class="agenda-index">{String(i + 1).padStart(2, '0')}</span>
                                <span class="agenda-label">{section.data.agendaLabel}</span>
                            </a>
                    ))}
                </nav>
            </div>
        </header>

        <div class="about-body">

            <!-- ── Main content ─────────────────────────── -->
            <div class="bio">
                {rendered.map(({section, Content}) => (
                        <section id={toId(section.id)} class="bio-section">
                            {section.data.subtitle && (
                                    <p class="bio-section-label">{section.data.subtitle}</p>
                            )}
                            <h2 class="bio-section-title">{section.data.sectionTitle}</h2>
                            <div class="bio-prose">
                                <Content/>
                            </div>
                        </section>
                ))}
            </div>

            <!-- ── Sidebar ─────────────────────────────── -->
            <aside class="sidebar">

                <div class="sidebar-block">
                    <p class="sidebar-label">Currently</p>
                    <ul class="sidebar-list">
                        {['Working at PwC', 'Based in Skopje, Macedonia', 'Open to side-hustle ideas'].map((item) => (
                                <li class="sidebar-item">{item}</li>
                        ))}
                    </ul>
                </div>

                <div class="sidebar-block">
                    <p class="sidebar-label">Engineering Stack</p>
                    <div class="tag-row">
                        {stack.map((tech) => <span class="tag-stack">{tech}</span>)}
                    </div>
                </div>

                <div class="sidebar-block">
                    <p class="sidebar-label">AI / ML</p>
                    <div class="tag-row">
                        {aiStack.map((tech) => <span class="tag-stack">{tech}</span>)}
                    </div>
                </div>

                <div class="sidebar-block">
                    <p class="sidebar-label">Cloud Engineering</p>
                    <div class="tag-row">
                        {cloudStack.map((tech) => <span class="tag-stack">{tech}</span>)}
                    </div>
                </div>

                <div class="sidebar-block">
                    <p class="sidebar-label">Tooling & Practices</p>
                    <div class="tag-row">
                        {tooling.map((tech) => <span class="tag-stack">{tech}</span>)}
                    </div>
                </div>

                <div class="sidebar-block">
                    <p class="sidebar-label">Links</p>
                    <div class="link-col">
                        {[
                            {label: 'GitHub', href: 'https://github.com/tkovachka'},
                            {label: 'LinkedIn', href: 'https://www.linkedin.com/in/teodora-kovachka-37692134b'},
                            {label: 'Email', href: 'mailto:teodora.kovachka@gmail.com'},
                        ].map(({label, href}) => (
                                <a href={href}
                                   target={href.startsWith('http') ? '_blank' : undefined}
                                   rel="noopener"
                                   class="ext-link">
                                    {label} →
                                </a>
                        ))}
                    </div>
                </div>

            </aside>
        </div>

        <div class="page-footer-nav">
            <a href="/projects" class="footer-cta">See my projects →</a>
        </div>

    </div>

    <Footer slot="footer"/>
</BaseLayout>

<style>
    /* ── Page header ─────────────────────── */
    .page-header {
        margin-bottom: 4rem;
    }

    .header-grid {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 4rem;
        align-items: start;
        padding-bottom: 2rem;
        border-bottom: 1px solid #E8E8E8;
    }

    @media (max-width: 640px) {
        .header-grid {
            grid-template-columns: 1fr;
            gap: 2rem;
        }
    }

    .section-label {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--burgundy);
        margin-bottom: 0.75rem;
    }

    .page-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(3rem, 6vw, 4.5rem);
        font-weight: 700;
        color: #0D0D0D;
        line-height: 1.05;
        margin: 0;
        white-space: nowrap;
    }

    .page-title em {
        font-style: italic;
        color: var(--burgundy);
    }

    /* ── Agenda ──────────────────────────── */
    .agenda {
        display: flex;
        flex-direction: column;
        flex-wrap: wrap;
        gap: 0.45rem 2rem;
        height: 12rem;
        align-content: start;
        padding-top: 1.85rem;
    }

    @media (max-width: 640px) {
        .agenda {
            height: auto;
            flex-wrap: wrap;
            flex-direction: row;
            padding-top: 0;
        }
    }

    .agenda-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        text-decoration: none;
        padding: 0.35rem 0.85rem 0.35rem 0.6rem;
        border: 1px solid #E0E0E0;
        transition: border-color 0.2s, background 0.2s;
        width: fit-content;
    }

    .agenda-item:hover {
        border-color: var(--burgundy);
        background: var(--burgundy-pale);
    }

    .agenda-item:hover .agenda-index,
    .agenda-item:hover .agenda-label {
        color: var(--burgundy);
    }

    .agenda-index {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.6rem;
        color: #BBB;
        transition: color 0.2s;
    }

    .agenda-label {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: #555;
        transition: color 0.2s;
    }

    /* ── Body grid ───────────────────────── */
    .about-body {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 4rem;
        align-items: start;
        margin-bottom: 4rem;
    }

    @media (max-width: 768px) {
        .about-body {
            grid-template-columns: 1fr;
            gap: 3rem;
        }
    }

    /* ── Bio sections ────────────────────── */
    .bio-section {
        margin-bottom: 3.5rem;
        padding-top: 1rem;
        scroll-margin-top: 6rem;
    }

    .bio-section:last-child {
        margin-bottom: 0;
    }

    .bio-section-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.62rem;
        color: var(--burgundy);
        letter-spacing: 0.1em;
        margin-bottom: 0.4rem;
    }

    .bio-section-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(1.4rem, 2.5vw, 1.9rem);
        font-weight: 700;
        color: #0D0D0D;
        line-height: 1.2;
        margin-bottom: 1.1rem;
    }

    /* Prose rendered from Markdown */
    .bio-prose {
        font-family: 'DM Sans', sans-serif;
        font-size: 1rem;
        line-height: 1.85;
        color: #444;
    }

    .bio-prose :global(p) {
        text-indent: 2em;
        margin-bottom: 1.1rem;
    }

    .bio-prose :global(p:last-child) {
        margin-bottom: 0;
    }

    .bio-prose :global(strong) {
        color: #0D0D0D;
        font-weight: 600;
    }

    .bio-prose :global(em) {
        font-style: italic;
    }

    .bio-prose :global(a) {
        color: var(--burgundy);
        text-decoration: underline;
        text-underline-offset: 3px;
    }

    /* First paragraph of first section gets the larger lead treatment */
    .bio-section .bio-prose :global(p:first-child) {
        font-size: 1.1rem;
        font-weight: 500;
        color: #0D0D0D;
        line-height: 1.75;
        text-indent: 0;
    }

    /* ── Sidebar ─────────────────────────── */
    .sidebar {
        border-left: 2px solid var(--burgundy);
        padding-left: 1.75rem;
        position: sticky;
        top: 6rem;
    }

    .sidebar-block {
        margin-bottom: 2rem;
    }

    .sidebar-label {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--burgundy);
        margin-bottom: 0.6rem;
    }

    .sidebar-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }

    .sidebar-item {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.9rem;
        color: #333;
    }

    .tag-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
    }

    .tag-stack {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        color: #0D0D0D;
        border: 1px solid #D0D0D0;
        padding: 0.2rem 0.5rem;
    }

    .link-col {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .ext-link {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: #0D0D0D;
        text-decoration: none;
        border-bottom: 1px solid #0D0D0D;
        padding-bottom: 1px;
        transition: color 0.2s, border-color 0.2s;
    }

    .ext-link:hover {
        color: var(--burgundy);
        border-color: var(--burgundy);
    }

    /* ── Footer nav ──────────────────────── */
    .page-footer-nav {
        border-top: 1px solid #E8E8E8;
        padding-top: 2.5rem;
    }

    .footer-cta {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #0D0D0D;
        text-decoration: none;
        border-bottom: 2px solid #0D0D0D;
        padding-bottom: 2px;
        transition: color 0.2s, border-color 0.2s;
    }

    .footer-cta:hover {
        color: var(--burgundy);
        border-color: var(--burgundy);
    }
</style>